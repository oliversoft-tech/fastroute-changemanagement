      "id": "a1",
      "name": "Impact Form",
      "type": "n8n-nodes-base.formTrigger",
      "typeVersion": 2,
      "position": [
        -1160,
        100
      ]
    },
    {
      "parameters": {
        "jsCode": "const input = $json;\n\nconst normalize = (value) =>\n  String(value || '')\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .toLowerCase()\n    .trim();\n\nconst getByExactOrHint = (exactKeys, hints, fallback = '') => {\n  for (const key of exactKeys) {\n    if (input[key] !== undefined && input[key] !== null && String(input[key]).trim() !== '') {\n      return String(input[key]).trim();\n    }\n  }\n\n  const entries = Object.entries(input);\n  for (const hint of hints) {\n    const h = normalize(hint);\n    const found = entries.find(([k, v]) => normalize(k).includes(h) && v !== undefined && v !== null && String(v).trim() !== '');\n    if (found) return String(found[1]).trim();\n  }\n\n  return fallback;\n};\n\nconst problem = getByExactOrHint(\n  [\n    'Qual problema ou oportunidade essa alteração resolve?',\n    'Qual problema ou oportunidade essa alteracao resolve?'\n  ],\n  ['problema ou oportunidade', 'problema'],\n  'Nao informado'\n);\n\nconst expectedChange = getByExactOrHint(\n  ['Descreva a mudança como você espera ver no produto', 'Descreva a mudanca como voce espera ver no produto'],\n  ['mudanca como voce espera ver no produto', 'mudanca esperada', 'como voce espera ver no produto'],\n  'Nao informado'\n);\n\nconst readinessEvidence = getByExactOrHint(\n  ['Quais evidências comprovam que a entrega está pronta?', 'Quais evidencias comprovam que a entrega esta pronta?'],\n  ['evidencias comprovam que a entrega esta pronta', 'evidencias', 'entrega pronta'],\n  'Nao informado'\n);\n\nconst constraints = getByExactOrHint(\n  ['Restrições: Limites de prazo, compliance, integrações proibidas, etc.', 'Restricoes: Limites de prazo, compliance, integracoes proibidas, etc.'],\n  ['restricoes', 'compliance', 'integracoes proibidas', 'limites de prazo'],\n  'Nenhuma restricao informada'\n);\n\nconst owner = 'oliversoft-tech';\nconst repo = 'fastroute-changemanagement';\nconst impactWorkflow = 'impact-analysis.yml';\n\n// Token fixo, como voce pediu\nconst githubToken = 'COLE_SEU_GITHUB_TOKEN_AQUI';\n\nconst request_text = [\n  'Problema/Oportunidade',\n  problem,\n  '',\n  'Mudanca esperada no produto',\n  expectedChange,\n  '',\n  'Evidencias de pronto',\n  readinessEvidence,\n  '',\n  'Restricoes',\n  constraints\n].join('\\n');\n\nconst startedAt = new Date().toISOString();\n\nreturn [{\n  owner,\n  repo,\n  impact_workflow: impactWorkflow,\n  github_token: githubToken,\n  request_text,\n  started_at: startedAt,\n  deploy_api: false,\n  // Defaults fixos para governanca\n  domain_ref: 'main',\n  api_ref: 'main',\n  mobile_ref: 'main',\n  mobile_profile: 'preview'\n}];\n"
      },
