    {
      "parameters": {
        "jsCode": "const body = $json;\nconst base = $item(0).$node['Normalize'].json;\nconst startedAt = new Date(base.started_at).getTime() - 120000;\nconst runs = Array.isArray(body.workflow_runs) ? body.workflow_runs : [];\nconst candidate = runs\n  .filter(r => new Date(r.created_at).getTime() >= startedAt)\n  .sort((a, b) => new Date(b.created_at).getTime() - new Date(a.created_at).getTime())[0];\n\nif (!candidate) {\n  return [{ ...base, run_found: false }];\n}\n\nreturn [{\n  ...base,\n  run_found: true,\n  impact_run_id: candidate.id,\n  impact_run_url: candidate.html_url\n}];"
      },
