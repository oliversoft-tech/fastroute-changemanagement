    {
      "parameters": {
        "jsCode": "const base = $item(0).$node['Merge Run Status'].json;\nconst artifacts = Array.isArray($json.artifacts) ? $json.artifacts : [];\nconst report = artifacts.find(a => a.name === 'impact-analysis-report') || artifacts[0];\nconst artifactUrl = report ? report.archive_download_url : '';\n\nconst q = new URLSearchParams({\n  owner: base.owner,\n  repo: base.repo,\n  token: base.github_token,\n  deploy_api: String(base.deploy_api),\n  domain_ref: base.domain_ref,\n  api_ref: base.api_ref,\n  mobile_ref: base.mobile_ref,\n  mobile_profile: base.mobile_profile\n});\n\nconst approveUrl = `https://SEU_N8N/webhook/fastroute-impact-decision?approve=true&${q.toString()}`;\nconst rejectUrl = `https://SEU_N8N/webhook/fastroute-impact-decision?approve=false&${q.toString()}`;\n\nreturn [{\n  ok: base.conclusion === 'success',\n  conclusion: base.conclusion,\n  impact_run_url: base.impact_run_url,\n  artifact_download_url: artifactUrl,\n  mensagem: base.conclusion === 'success'\n    ? 'Analise concluida. Revise o relatorio e escolha Aprovar/Rejeitar.'\n    : 'Analise concluida com falha. Corrija antes de aprovar governanca.',\n  aprovar_url: approveUrl,\n  rejeitar_url: rejectUrl\n}];"
      },
